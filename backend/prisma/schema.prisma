generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Module {
  id                 String          @id @default(cuid())
  number             Int             @unique
  title              String
  subtitle           String
  level              String
  estimatedTime      String
  description        String
  learningObjectives String[]
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  activities         Activity[]
  certifications     Certification[]
  certificates       Certificate[]
  lessons            Lesson[]
  quizzes            Quiz[]

  @@index([number])
}

model Lesson {
  id         String           @id @default(cuid())
  moduleId   String
  order      Int
  title      String
  content    Json
  keyInsight String?
  video      Json?
  module     Module           @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  progress   LessonProgress[]

  @@unique([moduleId, order])
  @@index([moduleId, order])
}

model Quiz {
  id          String           @id @default(cuid())
  moduleId    String
  title       String
  questions   Json
  type        String
  module      Module           @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  submissions QuizSubmission[]

  @@index([moduleId, type])
}

model Learner {
  id              String           @id @default(cuid())
  email           String           @unique
  password        String
  name            String
  avatar          String?
  enrolledAt      DateTime         @default(now())
  currentStreak   Int              @default(0)
  lastActivityAt  DateTime         @default(now())
  certificates    Certificate[]
  progress        LessonProgress[]
  quizSubmissions QuizSubmission[]
  payments        Payment[]

  @@index([email])
}

model LessonProgress {
  id          String    @id @default(cuid())
  learnerId   String
  lessonId    String
  completed   Boolean   @default(false)
  completedAt DateTime?
  timeSpent   Int?
  learner     Learner   @relation(fields: [learnerId], references: [id], onDelete: Cascade)
  lesson      Lesson    @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([learnerId, lessonId])
  @@index([learnerId])
  @@index([lessonId])
}

model QuizSubmission {
  id              String         @id @default(cuid())
  learnerId       String
  quizId          String?
  certificationId String?
  answers         Json
  score           Int
  maxScore        Int
  passed          Boolean
  submittedAt     DateTime       @default(now())
  learner         Learner        @relation(fields: [learnerId], references: [id], onDelete: Cascade)
  quiz            Quiz?          @relation(fields: [quizId], references: [id], onDelete: Cascade)
  certification   Certification? @relation(fields: [certificationId], references: [id], onDelete: Cascade)

  @@index([learnerId, quizId])
  @@index([learnerId, certificationId])
  @@index([submittedAt])
}

model Certificate {
  id              String    @id @default(cuid())
  learnerId       String
  moduleId        String
  certificateId   String    @unique
  earnedAt        DateTime  @default(now())
  verificationUrl String?
  learner         Learner   @relation(fields: [learnerId], references: [id], onDelete: Cascade)
  module          Module    @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  payment         Payment?

  @@unique([learnerId, moduleId])
  @@index([certificateId])
  @@index([learnerId])
}

model Payment {
  id                  String    @id @default(cuid())
  learnerId           String
  certificateId       String    @unique
  amount              Decimal   @db.Decimal(10, 2)
  phoneNumber         String
  merchantRequestId   String?
  checkoutRequestId   String?   @unique
  mpesaReceiptNumber  String?   @unique
  transactionDate     DateTime?
  status              String    @default("PENDING")
  resultCode          String?
  resultDesc          String?
  metadata            Json?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  learner             Learner   @relation(fields: [learnerId], references: [id], onDelete: Cascade)
  certificate         Certificate @relation(fields: [certificateId], references: [id], onDelete: Cascade)

  @@index([learnerId])
  @@index([checkoutRequestId])
  @@index([mpesaReceiptNumber])
  @@index([status])
}

model Activity {
  id          String @id @default(cuid())
  moduleId    String
  title       String
  description String
  content     Json
  module      Module @relation(fields: [moduleId], references: [id], onDelete: Cascade)
}

model Certification {
  id            String           @id @default(cuid())
  moduleId      String
  title         String
  requiredScore Int
  content       Json
  module        Module           @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  submissions   QuizSubmission[]
}
